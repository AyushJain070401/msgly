# ============================================================================
# messaging-hub example — environment variables
# ============================================================================
# Copy this file to `.env` and fill in only the channels you want to enable.
# The example server registers each adapter ONLY if its required vars are set,
# so you can connect channels one at a time as you get credentials.
# ============================================================================

# Optional — port the example server listens on. Default: 3000
PORT=3000

# ----------------------------------------------------------------------------
# Telegram
# ----------------------------------------------------------------------------
# 1. Open Telegram, message @BotFather
# 2. Send: /newbot — choose a name and username
# 3. BotFather replies with a token like "123456789:ABC-DEF..."
# 4. (Recommended) pick any random string for TELEGRAM_WEBHOOK_SECRET
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# LINE
# ----------------------------------------------------------------------------
# 1. Sign up at https://developers.line.biz
# 2. Create a Provider, then create a Messaging API channel inside it
# 3. CHANNEL ACCESS TOKEN: Messaging API tab → "Channel access token (long-lived)"
#    → click Issue
# 4. CHANNEL SECRET: Basic settings tab → Channel secret
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ----------------------------------------------------------------------------
# Meta family — Messenger, Instagram, WhatsApp all share these two vars
# ----------------------------------------------------------------------------
# These come from your single Meta App at https://developers.facebook.com
# 1. Create an app (Business type)
# 2. APP_SECRET: Settings → Basic → App Secret (click Show)
# 3. VERIFY_TOKEN: pick any random string. You'll set the same value
#    when subscribing webhooks in Meta dashboard.
META_APP_SECRET=
META_VERIFY_TOKEN=

# ----------------------------------------------------------------------------
# Messenger (uses the META_APP_SECRET above)
# ----------------------------------------------------------------------------
# 1. In your Meta App, add the "Messenger" product
# 2. Settings → Access Tokens → select your Facebook Page → Generate Token
# 3. Subscribe to webhook events: messages, messaging_postbacks
MESSENGER_PAGE_TOKEN=

# ----------------------------------------------------------------------------
# Instagram (uses the META_APP_SECRET above)
# ----------------------------------------------------------------------------
# Prerequisite: your Instagram account must be Business or Creator type AND
# linked to a Facebook Page.
# 1. In your Meta App, under Messenger → Instagram Settings, link the Page
# 2. Generate Token (the SAME page token works for Instagram messaging)
# 3. Subscribe to webhook events: messages
INSTAGRAM_PAGE_TOKEN=

# ----------------------------------------------------------------------------
# WhatsApp Cloud API (uses the META_APP_SECRET above)
# ----------------------------------------------------------------------------
# 1. In your Meta App, add the "WhatsApp" product
# 2. API Setup tab — Meta gives you a free test phone number
# 3. PHONE_NUMBER_ID: API Setup → "Phone number ID" (the long numeric one,
#    NOT the human-readable phone number)
# 4. ACCESS_TOKEN: API Setup → "Temporary access token" (24h, fine for testing).
#    For production, generate a permanent System User token in Business Settings
#    → Users → System Users → Generate New Token.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# Discord (HTTP Interactions — slash commands & button clicks)
# ----------------------------------------------------------------------------
# Requires Node 20.13+ (for WebCrypto Ed25519). Bun/Deno/Edge runtimes also work.
# 1. Create an app at https://discord.com/developers/applications
# 2. APPLICATION_ID + PUBLIC_KEY: General Information tab
# 3. BOT_TOKEN: Bot tab → Reset Token (shown ONCE — copy immediately)
# 4. Paste <PUBLIC_URL>/webhook/discord into the "Interactions Endpoint URL"
#    field on General Information and click Save Changes. Your server must be
#    running so it can answer Discord's PING with a PONG.
# 5. Register a /echo slash command via the curl recipe in the README.
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# ----------------------------------------------------------------------------
# Microsoft Teams (Bot Framework)
# ----------------------------------------------------------------------------
# Needs an Azure subscription (free tier is fine).
# 1. Azure portal → Azure AD → App registrations → New registration.
#    Copy the Application (client) ID → MSTEAMS_APP_ID.
# 2. Same app → Certificates & secrets → New client secret. Copy the Value
#    immediately (shown ONCE) → MSTEAMS_APP_PASSWORD.
# 3. Azure portal → Create resource → "Azure Bot". Choose "Use existing app
#    registration" and paste MSTEAMS_APP_ID. Pricing F0 (free) is fine.
# 4. Bot resource → Configuration → Messaging endpoint:
#    <PUBLIC_URL>/webhook/msteams
# 5. Bot resource → Channels → click Microsoft Teams → accept terms.
# 6. dev.teams.microsoft.com → Apps → New app → Bot → select the bot above.
#    Publish to your org or "Preview in Teams" for testing.
MSTEAMS_APP_ID=
MSTEAMS_APP_PASSWORD=

# ----------------------------------------------------------------------------
# Gmail (Pub/Sub push — one bot mailbox)
# ----------------------------------------------------------------------------
# Full setup in packages/adapter-gmail/README.md. Summary:
# 1. Google Cloud → enable Gmail API. Credentials → OAuth client ID.
#    Copy → GMAIL_CLIENT_ID, GMAIL_CLIENT_SECRET.
# 2. Run consent flow (in browser, signed in as the agent mailbox), exchange
#    code for tokens. Copy refresh_token → GMAIL_REFRESH_TOKEN.
# 3. GMAIL_EMAIL: the mailbox address (e.g. agent@yourco.com).
# 4. Pub/Sub topic → grant publisher to gmail-api-push@system.gserviceaccount.com.
# 5. Push subscription → endpoint <PUBLIC_URL>/webhook/gmail
#    Easiest dev option: append ?token=<random> to the URL and set
#    GMAIL_PUSH_TOKEN to that same value.
# 6. Call adapter.watch('projects/.../topics/...') once at deploy + daily.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_EMAIL=
GMAIL_PUSH_TOKEN=

# ----------------------------------------------------------------------------
# Outlook / Microsoft 365 (Graph change notifications — one bot mailbox)
# ----------------------------------------------------------------------------
# Full setup in packages/adapter-outlook/README.md. Summary:
# 1. Entra ID → App registrations → New. Copy Application (client) ID →
#    OUTLOOK_CLIENT_ID. Add a client secret → OUTLOOK_CLIENT_SECRET.
# 2. API permissions (Delegated): Mail.Read, Mail.Send, offline_access.
# 3. Run OAuth consent flow (in browser, agent mailbox). Exchange code →
#    refresh_token → OUTLOOK_REFRESH_TOKEN.
# 4. OUTLOOK_EMAIL: mailbox UPN (e.g. agent@yourco.com).
# 5. OUTLOOK_CLIENT_STATE: pick any random string. The adapter uses it as a
#    shared secret to verify notifications.
# 6. At deploy time, call adapter.createSubscription({ notificationUrl })
#    once, then adapter.renewSubscription(id) daily.
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REFRESH_TOKEN=
OUTLOOK_EMAIL=
OUTLOOK_CLIENT_STATE=
OUTLOOK_TENANT_ID=common
